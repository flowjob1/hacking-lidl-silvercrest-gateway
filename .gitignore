# Compiled objects and binaries
*.o
*.bin
*.elf
*.gbl
*.hex
*.s37

# Exception: pre-built firmware files (.gbl for UART flashing).
# .s37 files are not shipped except the combined bootloader image, which is
# the only artefact users need for the very first SWD flash. All other .s37s
# are produced as side-effects of the build and not useful for end-users.
!2-Zigbee-Radio-Silabs-EFR32/*/firmware/*.gbl
!2-Zigbee-Radio-Silabs-EFR32/23-Bootloader-UART-Xmodem/firmware/bootloader-uart-xmodem-*-combined.s37
# Exception: bootloader flash image
!3-Main-SoC-Realtek-RTL8196E/31-Bootloader/boot.bin
*.img
*.img.gz
# Exception: shipped kernel flash image
!3-Main-SoC-Realtek-RTL8196E/32-Kernel/kernel-6.18.img

