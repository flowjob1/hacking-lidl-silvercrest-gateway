--- a/net/core/skbuff.c
+++ b/net/core/skbuff.c
@@ -89,6 +89,13 @@
 int sysctl_max_skb_frags __read_mostly = MAX_SKB_FRAGS;
 EXPORT_SYMBOL(sysctl_max_skb_frags);

+/* Realtek private buffer pool support - vendor patch from 2.6.30
+ * Only active when the legacy rtl819x driver is compiled in. */
+#ifdef CONFIG_RTL819X
+extern int is_rtl865x_eth_priv_buf(unsigned char *head);
+extern void free_rtl865x_eth_priv_buf(unsigned char *head);
+#endif
+
 /**
  *	skb_panic - private function for out-of-line support
  *	@skb:	buffer
@@ -600,10 +606,16 @@ static void skb_free_head(struct sk_buff *skb)
 {
 	unsigned char *head = skb->head;

-	if (skb->head_frag)
+	if (skb->head_frag) {
 		skb_free_frag(head);
-	else
-		kfree(head);
+	} else {
+#ifdef CONFIG_RTL819X
+		if (is_rtl865x_eth_priv_buf(head))
+			free_rtl865x_eth_priv_buf(head);  /* return to private pool */
+		else
+#endif
+			kfree(head);
+	}
 }

 static void skb_release_data(struct sk_buff *skb)
