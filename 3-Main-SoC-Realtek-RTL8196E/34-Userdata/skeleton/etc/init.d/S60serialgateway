#!/bin/sh
#
# S60serialgateway — Init script to launch serialgateway
#
# Skipped when radio mode is set to "otbr" in /userdata/etc/radio.conf
#
# J. Nilo - Nov 2025
#

case "$1" in
start)
    # Skip if radio is configured for OTBR (serialgateway and otbr-agent
    # cannot share /dev/ttyS1)
    if [ -f /userdata/etc/radio.conf ] && grep -q '^MODE=otbr' /userdata/etc/radio.conf; then
        echo "Skipping serialgateway (radio mode: otbr)"
        exit 0
    fi

    echo "Starting serialgateway..."
    serialgateway
    ;;

stop)
    # Skip if radio is configured for OTBR (serialgateway was never started)
    if [ -f /userdata/etc/radio.conf ] && grep -q '^MODE=otbr' /userdata/etc/radio.conf; then
        exit 0
    fi

    echo "🔴 Stopping serialgateway..."
    killall serialgateway
    ;;

restart)
    $0 stop
    sleep 1
    $0 start
    ;;

*)
    echo "ℹ️ Usage: $0 {start|stop|restart}"
    exit 1
    ;;
esac

exit 0

