#!/bin/sh
# S70otbr — Start OpenThread Border Router agent
#
# Requires:
#   - Kernel with IPv6 + CONFIG_FILE_LOCKING
#   - EFR32 flashed with OT-RCP firmware
#   - otbr-agent binary in /userdata/usr/bin/
#
# Storage:
#   otbr-agent runs from tmpfs (/tmp/thread) to protect JFFS2 from flash
#   wear (frame counters update ~480 times/day). A background daemon polls
#   the active dataset every 30s and syncs to flash (/userdata/thread) only
#   when the dataset changes. On clean shutdown (SIGTERM), a final sync runs.
#   On power loss, only frame counters are lost — OpenThread recovers by
#   jumping ahead on next boot.

OTBR_BIN="/userdata/usr/bin/otbr-agent"

# UART settings — must match EFR32 OT-RCP firmware
RCP_URL="spinel+hdlc+uart:///dev/ttyS1?uart-baudrate=115200"

# Network interfaces
THREAD_IF="wpan0"
BACKBONE_IF="eth0"

# REST API — listen on all interfaces so HA can reach it
REST_LISTEN="::0"
REST_PORT="8081"

# Storage paths
FLASH_DIR="/userdata/thread"
RAM_DIR="/tmp/thread"
SYNC_PID="/tmp/otbr-sync.pid"

case "$1" in
start)
    [ -x "$OTBR_BIN" ] || exit 0

    # Only start if radio mode is set to "otbr" in /userdata/etc/radio.conf
    if ! [ -f /userdata/etc/radio.conf ] || ! grep -q '^MODE=otbr' /userdata/etc/radio.conf; then
        exit 0
    fi

    echo "Starting otbr-agent..."

    # Restore settings from flash to tmpfs
    mkdir -p "$FLASH_DIR" "$RAM_DIR"
    cp "$FLASH_DIR"/* "$RAM_DIR"/ 2>/dev/null

    # Enable IPv6 forwarding (required for border routing)
    echo 1 > /proc/sys/net/ipv6/conf/all/forwarding

    $OTBR_BIN \
        -d 4 \
        -I "$THREAD_IF" \
        -B "$BACKBONE_IF" \
        --rest-listen-address "$REST_LISTEN" \
        --rest-listen-port "$REST_PORT" \
        --vendor-name "Lidl" \
        --model-name "Silvercrest" \
        --data-path "$RAM_DIR" \
        "$RCP_URL" &

    # Reduce log level from info to warn (0=none 1=crit 2=warn 3=note 4=info)
    sleep 2
    /userdata/usr/bin/ot-ctl log level 2 >/dev/null 2>&1 || true
    # Note: log level has no REST API equivalent, ot-ctl is used once at startup

    # Persistent dataset sync + Status LED daemon (background)
    # Polls the REST API every 30s (avoids ot-ctl broken pipe warnings).
    # Syncs dataset to flash on change, turns LED on when Thread is formed.
    (
        trap 'echo 0 > /sys/class/leds/status/brightness; exit 0' TERM INT
        REST="http://127.0.0.1:${REST_PORT}"
        LED="/sys/class/leds/status/brightness"
        last_led=""
        sleep 5  # let otbr-agent start before first poll
        # Seed last_dataset so first poll doesn't trigger a redundant write
        last_dataset=$(wget -qO- "$REST/node/dataset/active" 2>/dev/null)
        while true; do
            # LED: on when Thread state is child, router, or leader
            state=$(wget -qO- "$REST/node/state" 2>/dev/null)
            case "$state" in
                *child*|*router*|*leader*) led=1 ;;
                *) led=0 ;;
            esac
            if [ "$led" != "$last_led" ]; then
                echo "$led" > "$LED"
                last_led="$led"
            fi
            # Dataset sync — only write to flash when dataset actually changes
            dataset=$(wget -qO- "$REST/node/dataset/active" 2>/dev/null)
            case "$dataset" in
                "") ;;
                "$last_dataset") ;;
                *) cp "$RAM_DIR"/* "$FLASH_DIR"/ 2>/dev/null
                   last_dataset="$dataset" ;;
            esac
            # Poll fast (5s) until Thread is up, then slow (30s)
            [ "$led" = "1" ] && sleep 30 || sleep 5
        done
    ) &
    echo $! > "$SYNC_PID"
    ;;

stop)
    echo "Stopping otbr-agent..."
    # Reset LED
    echo 0 > /sys/class/leds/status/brightness
    # Stop sync loop
    [ -f "$SYNC_PID" ] && kill "$(cat "$SYNC_PID")" 2>/dev/null && rm -f "$SYNC_PID"
    killall otbr-agent 2>/dev/null
    ;;

restart)
    $0 stop
    sleep 1
    $0 start
    ;;

*)
    echo "Usage: $0 {start|stop|restart}"
    exit 1
    ;;
esac

exit 0
