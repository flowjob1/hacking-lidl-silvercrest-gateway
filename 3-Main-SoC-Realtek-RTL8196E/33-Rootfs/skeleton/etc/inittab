# /etc/inittab - init configuration for busybox init
#
# Minimal inittab in squashfs rootfs - boots system and mounts /userdata
# Full configuration is in /userdata/etc/inittab (loaded after mount)
#
::sysinit:/etc/init.d/rcS
ttyS0::respawn:/sbin/getty -L 38400 ttyS0 vt100
::shutdown:/userdata/etc/init.d/rcK
